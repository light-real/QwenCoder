/* ═══════════════════════════════════════════════════════
   全局基础样式  —  极简暗色 / OKX·Bybit 风格
   色彩系统：
     背景  #0a0b0d (近纯黑)
     卡片  #13151a
     边线  rgba(255,255,255,0.06)
     主绿  #00c076   主红  #ff5353
     主蓝  #3b82f6   金黄  #f0b90b
   ════════════════════════════════════════════════════════ */

page {
  background-color: #0a0b0d;
  color: #e8eaf2;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── 通用上升/下降颜色 ─────────────────────────── */
.up   { color: #00c076; }
.down { color: #ff5353; }

/* ── 磨砂玻璃卡片基础 ──────────────────────────── */
.glass-card {
  background: rgba(255,255,255,0.035);
  border: 1rpx solid rgba(255,255,255,0.07);
  border-radius: 20rpx;
  backdrop-filter: blur(12px);
}

/* ── 通用板块标题 ──────────────────────────────── */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #9098b0;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── 通用空状态 ───────────────────────────────── */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #3a3d4a;
}

.empty-state text {
  display: block;
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #2e313c;
}

/* ── 历史记录列表 ─────────────────────────────── */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.history-item {
  background: #13151a;
  border-radius: 18rpx;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.history-type {
  display: inline-block;
  padding: 5rpx 18rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  letter-spacing: 0.06em;
}

.history-type.buy  { background: rgba(0,192,118,0.12); color: #00c076; }
.history-type.sell { background: rgba(255,83,83,0.12);  color: #ff5353; }

.history-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8eaf2;
  margin-bottom: 6rpx;
}

.history-code {
  font-size: 22rpx;
  color: #454860;
  margin-bottom: 16rpx;
}

.detail-label { color: #5a5f75; font-size: 24rpx; }
.detail-value { color: #c8cad8; font-size: 24rpx; font-weight: 600; }

.history-time {
  font-size: 22rpx;
  color: #383b4a;
  margin-top: 14rpx;
}

.history-profit { font-size: 28rpx; font-weight: 700; }
.profit-up   { color: #00c076; }
.profit-down { color: #ff5353; }

/* ── 资产明细网格 ─────────────────────────────── */
.assets-breakdown {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding: 0 24rpx;
  margin-bottom: 28rpx;
}

.breakdown-item {
  background: #13151a;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.05);
}

.breakdown-label {
  font-size: 22rpx;
  color: #5a5f75;
  margin-bottom: 10rpx;
}

.breakdown-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8eaf2;
}

/* ── 持仓行 ──────────────────────────────────── */
.stock-holdings { margin-right: 20rpx; }

.holding-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
  gap: 16rpx;
}

.holding-label { color: #5a5f75; font-size: 24rpx; }
.holding-value { color: #c8cad8; font-size: 24rpx; font-weight: 600; }

/* ── 排行榜 ──────────────────────────────────── */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 24rpx;
}

.rank-item {
  background: #13151a;
  border-radius: 18rpx;
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.rank-item.me {
  background: linear-gradient(135deg, #0d1e38 0%, #102244 100%);
  border: 1rpx solid rgba(59,130,246,0.35);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #5a5f75;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.rank-number.top-1 { background: linear-gradient(135deg,#fbbf24,#f59e0b); color:#fff; }
.rank-number.top-2 { background: linear-gradient(135deg,#c8cdd8,#9ca3af); color:#fff; }
.rank-number.top-3 { background: linear-gradient(135deg,#d97706,#b45309); color:#fff; }

.rank-name  { font-size: 28rpx; font-weight: 600; color: #e8eaf2; margin-bottom: 5rpx; }
.rank-assets{ font-size: 22rpx; color: #5a5f75; }

.profit-text    { font-size: 28rpx; font-weight: 700; text-align: right; margin-bottom: 4rpx; }
.profit-percent { font-size: 22rpx; text-align: right; color: #5a5f75; }

.my-rank    { text-align: center; margin-bottom: 16rpx; }
.rank-label { font-size: 26rpx; color: #5a5f75; margin-bottom: 8rpx; }
.rank-value { font-size: 52rpx; font-weight: 700; color: #3b82f6; }

.profit-amount  { font-size: 40rpx; font-weight: 700; text-align: center; margin-bottom: 8rpx; }
.profit-rate    { font-size: 28rpx; text-align: center; }

/* ── 筛选按钮组 ──────────────────────────────── */
.filter-section {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 24rpx 0;
  margin-bottom: 20rpx;
}

.filter-btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255,255,255,0.03);
  color: #5a5f75;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.filter-btn.active {
  background: rgba(59,130,246,0.15);
  color: #3b82f6;
  border-color: rgba(59,130,246,0.3);
}

/* ── 旧式 stock-item（持仓/记录页兼容） ─────── */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stock-item {
  background: #13151a;
  border-radius: 18rpx;
  padding: 26rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.stock-item:active { opacity: 0.8; transform: scale(0.985); }

.stock-info { flex: 1; }
.stock-name { font-size: 30rpx; font-weight: 700; color: #e8eaf2; margin-bottom: 6rpx; }
.stock-code { font-size: 22rpx; color: #454860; font-weight: 500; letter-spacing: 0.04em; }

.stock-price { text-align: right; min-width: 160rpx; }

.price  { font-size: 34rpx; font-weight: 700; color: #e8eaf2; margin-bottom: 6rpx; letter-spacing: -0.01em; }

.change {
  font-size: 22rpx;
  font-weight: 600;
  padding: 5rpx 14rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.change-up   { color: #00c076; background: rgba(0,192,118,0.1); }
.change-down { color: #ff5353; background: rgba(255,83,83,0.1); }

/* ── 利润颜色（兼容旧命名） ───────────────────── */
.profit-positive { color: #00c076; font-weight: 600; }
.profit-negative { color: #ff5353; font-weight: 600; }
