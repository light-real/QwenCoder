page {
  background-color: #0f0f23;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.stock-item {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stock-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.stock-code {
  font-size: 24rpx;
  color: #888;
}

.stock-price {
  text-align: right;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.change {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.change-up {
  color: #f23645;
  background: rgba(242, 54, 69, 0.1);
}

.change-down {
  color: #0891b2;
  background: rgba(8, 145, 178, 0.1);
}

.btn {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

.btn-buy {
  background: linear-gradient(135deg, #f23645 0%, #ff4757 100%);
}

.btn-sell {
  background: linear-gradient(135deg, #0891b2 0%, #06b6d4 100%);
}

.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 30rpx;
  border-radius: 0 0 30rpx 30rpx;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 20rpx;
}

.total-assets {
  text-align: center;
  margin-bottom: 20rpx;
}

.assets-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.assets-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #e94560;
}

.profit-info {
  text-align: center;
  font-size: 28rpx;
}

.profit-positive {
  color: #f23645;
}

.profit-negative {
  color: #0891b2;
}
