<view class="container">
  <!-- 顶部我的战绩卡片 -->
  <view class="header-card">
    <view class="header-title">收益排行</view>
    <view class="my-stats">
      <view class="my-rank-badge">
        <text class="rank-no">#{{userRank}}</text>
        <text class="rank-label">我的排名</text>
      </view>
      <view class="my-divider"></view>
      <view class="my-profit-wrap">
        <view class="my-profit {{profit >= 0 ? 'up' : 'down'}}">
          {{profit >= 0 ? '▲' : '▼'}} {{profit >= 0 ? '+' : ''}}${{profit}}
        </view>
        <view class="my-rate {{profit >= 0 ? 'up' : 'down'}}">
          收益率 {{profit >= 0 ? '+' : ''}}{{profitRate}}%
        </view>
      </view>
    </view>
  </view>

  <!-- 排行榜列表 -->
  <view class="rank-section">
    <view class="section-header">
      <text class="section-title">榜单</text>
    </view>

    <view class="rank-list">
      <view
        wx:for="{{rankList}}"
        wx:key="index"
        class="rank-card {{item.isMe ? 'me' : ''}}"
      >
        <!-- 名次 -->
        <view class="rank-num {{index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : ''}}">
          <text wx:if="{{index === 0}}">🥇</text>
          <text wx:elif="{{index === 1}}">🥈</text>
          <text wx:elif="{{index === 2}}">🥉</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <!-- 名称 -->
        <view class="rank-info">
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-assets">总资产 ${{item.assets}}</text>
        </view>
        <!-- 收益 -->
        <view class="rank-profit-wrap">
          <text class="rank-profit {{item.profit >= 0 ? 'up' : 'down'}}">
            {{item.profit >= 0 ? '+' : ''}}${{item.profit}}
          </text>
          <text class="rank-rate {{item.profit >= 0 ? 'up' : 'down'}}">
            {{item.profit >= 0 ? '+' : ''}}{{item.profitRate}}%
          </text>
        </view>
      </view>
    </view>
  </view>
</view>
