<view class="container">
  <view class="header">
    <view class="header-title">Ranking</view>
    <view class="my-rank">
      <view class="rank-label">My Rank</view>
      <view class="rank-value">#{{userRank}}</view>
    </view>
    <view class="my-profit">
      <view class="profit-amount {{profit >= 0 ? 'profit-up' : 'profit-down'}}">
        {{profit >= 0 ? '+' : ''}}Å0Ñ6{{profit}}
      </view>
      <view class="profit-rate {{profit >= 0 ? 'profit-up' : 'profit-down'}}">
        Return: {{profitRate}}%
      </view>
    </view>
  </view>

  <view class="rank-list">
    <view wx:for="{{rankList}}" wx:key="index"
          class="rank-item {{item.isMe ? 'me' : ''}}">
      <view class="rank-number {{index < 3 ? 'top-' + (index + 1) : ''}}">
        {{index + 1}}
      </view>
      <view class="rank-info">
        <view class="rank-name">{{item.name}}</view>
        <view class="rank-assets">Assets: Å0Ñ6{{item.assets}}</view>
      </view>
      <view class="rank-profit">
        <view class="profit-text {{item.profit >= 0 ? 'profit-up' : 'profit-down'}}">
          {{item.profit >= 0 ? '+' : ''}}Å0Ñ6{{item.profit}}
        </view>
        <view class="profit-percent {{item.profit >= 0 ? 'profit-up' : 'profit-down'}}">
          {{item.profit >= 0 ? '+' : ''}}{{(item.profit / item.initialAssets * 100).toFixed(2)}}%
        </view>
      </view>
    </view>
  </view>
</view>
