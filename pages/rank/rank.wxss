.my-rank {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.rank-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.rank-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #e94560;
}

.my-profit {
  text-align: center;
}

.profit-amount {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.profit-rate {
  font-size: 28rpx;
}

.profit-up {
  color: #f23645;
}

.profit-down {
  color: #0891b2;
}

.rank-list {
  padding: 20rpx;
}

.rank-item {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.rank-item.me {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  box-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.3);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #888;
  margin-right: 20rpx;
}

.rank-number.top-1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  color: #fff;
}

.rank-number.top-2 {
  background: linear-gradient(135deg, #c0c0c0 0%, #a8a8a8 100%);
  color: #fff;
}

.rank-number.top-3 {
  background: linear-gradient(135deg, #cd7f32 0%, #b8690f 100%);
  color: #fff;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.rank-assets {
  font-size: 26rpx;
  color: #888;
}

.rank-profit {
  text-align: right;
}

.profit-text {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.profit-percent {
  font-size: 24rpx;
}
