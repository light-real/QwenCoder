.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
  padding: 0;
}

.header-card {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.95) 100%);
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.symbol-info {
  margin-bottom: 20rpx;
}

.symbol-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: -0.02em;
}

.symbol-code {
  font-size: 28rpx;
  color: #888;
  font-weight: 500;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.current-price {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.03em;
}

.price-change {
  font-size: 32rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.price-change.positive {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.price-change.negative {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.connection-badge {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.connection-badge.connected {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.connection-badge.disconnected {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.connection-badge.connected .badge-dot {
  background: #22c55e;
  box-shadow: 0 0 12rpx #22c55e;
  animation: pulse 2s infinite;
}

.connection-badge.disconnected .badge-dot {
  background: #ef4444;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.kline-card {
  margin: 30rpx;
  background: linear-gradient(135deg, #1e1e32 0%, #252540 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.kline-header {
  margin-bottom: 20rpx;
}

.kline-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.interval-badge {
  background: rgba(59, 130, 246, 0.2);
  color: #3b82f6;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.kline-controls {
  display: flex;
  gap: 16rpx;
}

.interval-group {
  display: flex;
  gap: 8rpx;
  flex: 1;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.interval-group::-webkit-scrollbar {
  display: none;
}

.interval-btn {
  flex-shrink: 0;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #888;
  text-align: center;
  transition: all 0.2s ease;
  border: 1rpx solid transparent;
}

.interval-btn.active {
  background: rgba(59, 130, 246, 0.2);
  color: #3b82f6;
  border-color: rgba(59, 130, 246, 0.5);
}

.tools-group {
  display: flex;
  gap: 8rpx;
}

.tool-btn {
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #888;
  transition: all 0.2s ease;
}

.tool-btn.active {
  background: rgba(234, 179, 8, 0.2);
  color: #eab308;
}

.kline-chart-wrapper {
  margin: 20rpx 0;
  background: #0a0a14;
  border-radius: 16rpx;
  overflow: hidden;
}

.kline-canvas {
  width: 100%;
  height: 500rpx;
}

.kline-info-panel {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
}

.info-value.high {
  color: #ef4444;
}

.info-value.low {
  color: #22c55e;
}

.trade-card {
  margin: 30rpx;
  background: linear-gradient(135deg, #1e1e32 0%, #252540 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.trade-tabs {
  display: flex;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.trade-tab {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
  transition: all 0.3s ease;
}

.trade-tab.active {
  color: #fff;
  position: relative;
}

.trade-tab.active.buy {
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
}

.trade-tab.active.sell {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.trade-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.trade-tab.active.buy::after {
  background: #22c55e;
}

.trade-tab.active.sell::after {
  background: #ef4444;
}

.trade-form {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-wrapper {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.quick-amounts {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.amount-btn {
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #888;
  text-align: center;
  transition: all 0.2s ease;
}

.amount-btn:active {
  transform: scale(0.95);
}

.amount-btn.highlight {
  background: rgba(59, 130, 246, 0.2);
  color: #3b82f6;
}

.info-grid.compact {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.total {
  padding-top: 16rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.row-label {
  font-size: 28rpx;
  color: #888;
  font-weight: 500;
}

.row-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.row-value.primary {
  font-size: 32rpx;
  color: #22c55e;
}

.info-row.total .row-value.primary {
  color: #22c55e;
}

.trade-btn {
  width: 100%;
  padding: 32rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  transition: all 0.3s ease;
  border: none;
}

.trade-btn.buy {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

.trade-btn.sell {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.trade-btn[disabled] {
  opacity: 0.5;
  transform: none;
  box-shadow: none;
}

.footer-info {
  padding: 30rpx;
  text-align: center;
}

.data-source {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.data-source text {
  font-size: 24rpx;
  color: #666;
}

.reconnect-btn {
  padding: 12rpx 24rpx;
  background: rgba(59, 130, 246, 0.2);
  border-radius: 8rpx;
}

.reconnect-btn text {
  color: #3b82f6;
  font-size: 24rpx;
  font-weight: 600;
}
