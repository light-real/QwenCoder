.assets-breakdown {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.breakdown-item {
  flex: 1;
  background: #1a1a2e;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.breakdown-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.breakdown-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.stock-section {
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #e94560;
}

.stock-item {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stock-info {
  flex: 1;
}

.stock-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.stock-code {
  font-size: 24rpx;
  color: #888;
}

.stock-holdings {
  margin-right: 30rpx;
}

.holding-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.holding-label {
  color: #888;
  margin-right: 20rpx;
}

.holding-value {
  color: #fff;
}

.stock-price {
  text-align: right;
  min-width: 150rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.change {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}

.profit {
  font-size: 24rpx;
  color: #888;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #888;
  font-size: 32rpx;
}

.empty-hint {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}
