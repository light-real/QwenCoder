/* ===== 持仓页 ===== */
.container {
  background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部资产卡片 */
.header-card {
  background: linear-gradient(135deg, #0d0d22 0%, #151530 100%);
  padding: 40rpx 30rpx 36rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.header-label {
  font-size: 26rpx;
  color: #8888aa;
  margin-bottom: 8rpx;
}

.header-assets {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin-bottom: 12rpx;
}

.header-profit {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.profit-tag {
  font-size: 28rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 10rpx;
}

.profit-tag.up {
  color: #26c97a;
  background: rgba(38,201,122,0.12);
}

.profit-tag.down {
  color: #f04c5a;
  background: rgba(240,76,90,0.12);
}

.profit-rate {
  font-size: 26rpx;
  font-weight: 600;
}

.profit-rate.up { color: #26c97a; }
.profit-rate.down { color: #f04c5a; }

/* 资产拆分 */
.breakdown-row {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.04);
  border-radius: 18rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.breakdown-item {
  flex: 1;
  text-align: center;
}

.breakdown-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.08);
  margin: 0 16rpx;
}

.breakdown-label {
  font-size: 24rpx;
  color: #8888aa;
  margin-bottom: 8rpx;
  display: block;
}

.breakdown-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 持仓列表 */
.holdings-section {
  padding: 28rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ccccee;
  padding-left: 18rpx;
  border-left: 4rpx solid #3b82f6;
}

.section-count {
  font-size: 22rpx;
  color: #555577;
  background: rgba(255,255,255,0.04);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 持仓卡片 */
.holding-card {
  background: linear-gradient(135deg, #13132a 0%, #1b1b38 100%);
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.35);
  transition: all 150ms;
}

.holding-card:active {
  transform: scale(0.98);
  opacity: 0.88;
}

/* 卡片顶部：名称 + 价格 */
.holding-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.holding-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.holding-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.holding-code {
  font-size: 22rpx;
  color: #5555aa;
  letter-spacing: 0.04em;
}

.holding-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.holding-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.holding-change {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
}

.holding-change.up {
  color: #26c97a;
  background: rgba(38,201,122,0.12);
}

.holding-change.down {
  color: #f04c5a;
  background: rgba(240,76,90,0.12);
}

/* 分割线 */
.holding-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.06);
  margin-bottom: 20rpx;
}

/* 底部统计四格 */
.holding-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  font-size: 20rpx;
  color: #666688;
  margin-bottom: 6rpx;
  display: block;
}

.stat-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #ddddff;
  display: block;
}

.stat-value.pnl-up {
  color: #26c97a;
}

.stat-value.pnl-down {
  color: #f04c5a;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #555577;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: #444466;
}
