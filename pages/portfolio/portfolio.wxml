﻿<view class="container">
  <!-- 顶部资产总览 -->
  <view class="header-card">
    <view class="header-label">总资产</view>
    <view class="header-assets">${{totalAssets}}</view>
    <view class="header-profit">
      <text class="profit-tag {{totalProfit >= 0 ? 'up' : 'down'}}">
        {{totalProfit >= 0 ? '▲' : '▼'}} {{totalProfit >= 0 ? '+' : ''}}${{totalProfit}}
      </text>
      <text class="profit-rate {{totalProfit >= 0 ? 'up' : 'down'}}">
        {{totalProfit >= 0 ? '+' : ''}}{{profitRate}}%
      </text>
    </view>

    <!-- 资产拆分 -->
    <view class="breakdown-row">
      <view class="breakdown-item">
        <text class="breakdown-label">可用余额</text>
        <text class="breakdown-value">${{userData.cash}}</text>
      </view>
      <view class="breakdown-divider"></view>
      <view class="breakdown-item">
        <text class="breakdown-label">持仓市值</text>
        <text class="breakdown-value">${{holdingValue}}</text>
      </view>
    </view>
  </view>

  <!-- 持仓列表 -->
  <view class="holdings-section">
    <view class="section-header">
      <text class="section-title">我的持仓</text>
      <text class="section-count">{{stocks.length}} 个币种</text>
    </view>

    <block wx:if="{{stocks.length > 0}}">
      <view
        wx:for="{{stocks}}"
        wx:key="code"
        class="holding-card"
        bindtap="toTrade"
        data-code="{{item.code}}"
      >
        <view class="holding-top">
          <view class="holding-left">
            <text class="holding-name">{{item.name}}</text>
            <text class="holding-code">{{item.code}}</text>
          </view>
          <view class="holding-right">
            <text class="holding-price">${{item.currentPrice}}</text>
            <view class="holding-change {{item.change >= 0 ? 'up' : 'down'}}">
              {{item.change >= 0 ? '▲' : '▼'}} {{item.change >= 0 ? '+' : ''}}{{item.change}}%
            </view>
          </view>
        </view>
        <view class="holding-divider"></view>
        <view class="holding-stats">
          <view class="stat-item">
            <text class="stat-label">持有数量</text>
            <text class="stat-value">{{item.quantity}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">持仓成本</text>
            <text class="stat-value">${{item.cost}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">当前市值</text>
            <text class="stat-value">${{item.marketValue}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-label">盈亏</text>
            <text class="stat-value {{item.pnl >= 0 ? 'pnl-up' : 'pnl-down'}}">
              {{item.pnl >= 0 ? '+' : ''}}${{item.pnl}}
            </text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-wrap">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无持仓</text>
        <text class="empty-hint">前往行情页买入第一笔</text>
      </view>
    </block>
  </view>
</view>
