<view class="container">
  <!-- 顶部标题 -->
  <view class="header-card">
    <text class="header-title">交易记录</text>
    <text class="header-count">共 {{history.length}} 笔</text>
  </view>

  <!-- 筛选 Tab -->
  <view class="filter-section">
    <view
      class="filter-btn {{filterType === 'all' ? 'active' : ''}}"
      bindtap="filterHistory"
      data-type="all"
    >全部</view>
    <view
      class="filter-btn {{filterType === 'buy' ? 'active buy' : ''}}"
      bindtap="filterHistory"
      data-type="buy"
    >买入</view>
    <view
      class="filter-btn {{filterType === 'sell' ? 'active sell' : ''}}"
      bindtap="filterHistory"
      data-type="sell"
    >卖出</view>
  </view>

  <!-- 记录列表 -->
  <view class="history-list">
    <block wx:if="{{filteredHistory.length > 0}}">
      <view
        wx:for="{{filteredHistory}}"
        wx:key="index"
        class="history-card"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="card-left">
            <view class="type-badge {{item.type}}">
              {{item.type === 'buy' ? '买入' : '卖出'}}
            </view>
            <view class="card-name-wrap">
              <text class="card-name">{{item.name}}</text>
              <text class="card-code">{{item.code}}</text>
            </view>
          </view>
          <view class="card-right">
            <text class="card-amount {{item.type === 'buy' ? 'amount-buy' : 'amount-sell'}}">
              {{item.type === 'buy' ? '-' : '+'}}${{item.amount}}
            </text>
            <text class="card-time">{{item.time}}</text>
          </view>
        </view>

        <!-- 卡片底部详情 -->
        <view class="card-divider"></view>
        <view class="card-stats">
          <view class="card-stat">
            <text class="stat-label">数量</text>
            <text class="stat-value">{{item.quantity}}</text>
          </view>
          <view class="card-stat">
            <text class="stat-label">成交价</text>
            <text class="stat-value">${{item.price}}</text>
          </view>
          <view class="card-stat" wx:if="{{item.type === 'sell' && item.profit !== undefined}}">
            <text class="stat-label">盈亏</text>
            <text class="stat-value {{item.profit >= 0 ? 'pnl-up' : 'pnl-down'}}">
              {{item.profit >= 0 ? '+' : ''}}${{item.profit}}
            </text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="empty-wrap">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无{{filterType === 'buy' ? '买入' : filterType === 'sell' ? '卖出' : ''}}记录</text>
        <text class="empty-hint">完成第一笔交易后在此查看</text>
      </view>
    </block>
  </view>
</view>
