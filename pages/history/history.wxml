<view class="container">
  <view class="header">
    <view class="header-title">Transaction History</view>
  </view>

  <view class="filter-section">
    <view class="filter-btn {{filterType === 'all' ? 'active' : ''}}" 
          bindtap="filterHistory" data-type="all">All</view>
    <view class="filter-btn {{filterType === 'buy' ? 'active' : ''}}" 
          bindtap="filterHistory" data-type="buy">Buy</view>
    <view class="filter-btn {{filterType === 'sell' ? 'active' : ''}}" 
          bindtap="filterHistory" data-type="sell">Sell</view>
  </view>

  <view class="history-list">
    <block wx:if="{{history.length > 0}}">
      <view wx:for="{{history}}" wx:key="index"
            class="history-item {{item.type}}">
        <view class="history-left">
          <view class="history-type {{item.type}}">
            {{item.type === 'buy' ? 'Buy' : 'Sell'}}
          </view>
          <view class="history-name">{{item.name}}</view>
          <view class="history-code">{{item.code}}</view>
        </view>
        <view class="history-middle">
          <view class="history-detail">
            <text class="detail-label">Qty:</text>
            <text class="detail-value">{{item.quantity}}</text>
          </view>
          <view class="history-detail">
            <text class="detail-label">Price:</text>
            <text class="detail-value">Å0Ñ6{{item.price}}</text>
          </view>
          <view class="history-detail">
            <text class="detail-label">Amount:</text>
            <text class="detail-value">Å0Ñ6{{item.amount}}</text>
          </view>
        </view>
        <view class="history-right">
          <view class="history-time">{{item.time}}</view>
          <view wx:if="{{item.profit !== undefined}}" 
                class="history-profit {{item.profit >= 0 ? 'profit-up' : 'profit-down'}}">
            {{item.profit >= 0 ? '+' : ''}}Å0Ñ6{{item.profit}}
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="empty-state">
        <text>No Transactions</text>
        <text class="empty-hint">Start your first trade</text>
      </view>
    </block>
  </view>
</view>
